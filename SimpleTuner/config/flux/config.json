{
    "--resume_from_checkpoint": "latest",
    "--data_backend_config": "config/flux/multidatabackend.json",
    "--aspect_bucket_rounding": 2,
    "--seed": 42,
    "--minimum_image_size": 0,
    "--disable_benchmark": false,
    "--output_dir": "flux_output",
    "--lora_type": "standard",
    "--lora_rank": 128,
    "--max_train_steps": 20000,
    "--num_train_epochs": 0,
    "--checkpointing_steps": 2000,
    "--checkpoints_total_limit": 10,
    "--attention_mechanism": "diffusers",
    "--tracker_project_name": "HealthCard",
    "--tracker_run_name": "flux",
    "--report_to": "wandb",
    "--model_type": "lora", 
    "--pretrained_model_name_or_path": "<path to your local Flux.1[Dev] model>",
    "--model_family": "flux",
    "--train_batch_size": 4,
    "--gradient_checkpointing": "true",
    "--caption_dropout_probability": 0.05,
    "--resolution_type": "pixel_area",
    "--resolution": 1024,
    "--validation_seed": 42,
    "--validation_steps": "1000",
    "--validation_resolution": "1024x1024",
    "--validation_guidance": 5,
    "--validation_guidance_rescale": "0.0",
    "--validation_num_inference_steps": "50",   
    "--user_prompt_library": "config/flux/user_prompt_library.json",
    "--mixed_precision": "bf16",
    "--optimizer": "adamw_bf16",
    "--learning_rate": "1e-4",
    "--lr_scheduler": "polynomial",
    "--lr_warmup_steps": 100,
    "--validation_torch_compile": "false"
}